# RequestBite rbite environment configuration
# This file contains environment variables for the rbite CLI application

# Tunnel server URL - default to dev server
TUNNEL_SERVER_URL=https://api.dev.t.rbite.dev

# Local development override (uncomment to use local server)
# TUNNEL_SERVER_URL=http://localhost:8080

# Debug mode (set to "true" to enable debug logging)
DEBUG=false

# Timeout settings (in seconds)
CONNECTION_TIMEOUT=30
READ_TIMEOUT=60
WRITE_TIMEOUT=60